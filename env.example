# Copy to .env and fill in. On Railway, set these in the service Variables tab.

# PostGIS connection. On Railway the PostGIS plugin injects DATABASE_URL.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/swissland

# Pipeline run mode: full | refresh | oereb
RUN_MODE=full

# Restrict the first runs to the Lausanne pilot communes (recommended).
PILOT_ONLY=true

# Local-file fallback for cadastral parcels + buildings (cantonal export).
# Leave defaults if you register on viageo.ch and drop exports in /data/vd.
DATA_DIR=/data/vd
PARCELS_FILE=/data/vd/parcels_vd.gpkg
BUILDINGS_FILE=/data/vd/buildings_vd.gpkg
